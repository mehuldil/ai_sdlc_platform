    "clean:docs": "rm -f manual.html .manual.hash && echo 'Docs cleaned'"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "markdown-it-highlightjs": "^4.0.1",
    "markdown-it-anchor": "^8.6.7",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "html-validate": "^8.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
