{
  "name": "ai-sdlc-platform-docs",
  "version": "2.0.0",
  "description": "Professional documentation build system for AI-SDLC Platform",
  "type": "module",
  "scripts": {
    "build:docs": "node build-manual-enhanced.mjs",
    "build:docs:legacy": "node build-manual-html.mjs",
    "validate:docs": "node scripts/validate-docs.mjs",
